{
  "name": "meowcaller-js",
  "version": "0.2.2",
  "description": "WhatsApp VoIP library for Baileys call signaling, SRTP media, and audio/video adapters",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "test": "node --test src/**/*.test.js",
    "test:api": "node --test src/api.test.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "keywords": [
    "whatsapp",
    "voip",
    "baileys",
    "webrtc",
    "call"
  ],
  "homepage": "https://benslogs.dev/socials/",
  "license": "MIT",
  "files": [
    "src/",
    "types/"
  ],
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "node-datachannel": "^0.32.3",
    "pino": "^9.0.0",
    "protobufjs": "^7.4.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "typescript": "^5.9.3"
  }
}
